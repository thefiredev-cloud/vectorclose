# VectorClose — Environment Variables
# Copy to .env and fill in values. Never commit .env.

# LLM
OPENAI_API_KEY=

# Outreach
APOLLO_API_KEY=
INSTANTLY_API_KEY=
RESEND_API_KEY=

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/vectorclose
REDIS_URL=redis://localhost:6379

# CRM (optional)
HUBSPOT_API_KEY=
SALESFORCE_ACCESS_TOKEN=
SALESFORCE_INSTANCE_URL=

# Contracts (optional)
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_ACCOUNT_ID=

# Engine settings
DAILY_EMAIL_LIMIT=80
MIN_CONFIDENCE_THRESHOLD=0.75
ENABLE_LINKEDIN=false
PORT=3100
NODE_ENV=development
